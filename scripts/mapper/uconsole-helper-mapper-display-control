#!/usr/bin/env python3

from __future__ import annotations

import argparse
import subprocess
from pathlib import Path


BACKLIGHT_POWER = Path("/sys/class/backlight/backlight@0/bl_power")
BACKLIGHT_BRIGHTNESS = Path("/sys/class/backlight/backlight@0/brightness")
BACKLIGHT_MAX_BRIGHTNESS = Path("/sys/class/backlight/backlight@0/max_brightness")
FRAMEBUFFER_BLANK = Path("/sys/class/graphics/fb0/blank")
KEYBOARD_BACKLIGHT_SCRIPT = Path("~/WorkSpace/uconsole-keyboard/tools/keyboard_state.sh").expanduser()


def read_screen_off() -> bool:
    return BACKLIGHT_POWER.read_text(encoding="utf-8").strip() == "4"


def write_text(path: Path, value: str) -> None:
    path.write_text(value, encoding="utf-8")


def set_keyboard_backlight(level: int) -> None:
    if not KEYBOARD_BACKLIGHT_SCRIPT.exists():
        return
    subprocess.run(
        ["sudo", "-n", "bash", str(KEYBOARD_BACKLIGHT_SCRIPT), "set", "--backlight", str(level)],
        check=False,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        timeout=4,
    )


def set_display(on: bool) -> None:
    if on:
        write_text(FRAMEBUFFER_BLANK, "0")
        write_text(BACKLIGHT_POWER, "0")
    else:
        set_keyboard_backlight(0)
        write_text(FRAMEBUFFER_BLANK, "1")
        write_text(BACKLIGHT_POWER, "4")


def set_brightness(level: int) -> None:
    max_brightness = int(BACKLIGHT_MAX_BRIGHTNESS.read_text(encoding="utf-8").strip())
    level = max(1, min(max_brightness, level))
    write_text(BACKLIGHT_BRIGHTNESS, str(level))


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("action", choices=("toggle", "on", "off", "status", "brightness"))
    parser.add_argument("value", nargs="?")
    args = parser.parse_args()

    if args.action == "status":
        print("off" if read_screen_off() else "on")
        return 0
    if args.action == "brightness":
        if args.value is None:
            parser.error("brightness requires a level")
        set_brightness(int(args.value))
        return 0
    if args.action == "toggle":
        set_display(read_screen_off())
        return 0

    set_display(args.action == "on")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
