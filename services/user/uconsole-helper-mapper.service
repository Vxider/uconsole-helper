[Unit]
Description=uConsole input mapper
After=graphical-session.target
Wants=graphical-session.target

[Service]
Type=simple
Environment=XDG_RUNTIME_DIR=%t
Environment=WAYLAND_DISPLAY=wayland-0
Environment=DISPLAY=:0
ExecStart=%h/.local/share/uconsole-helper-mapper/uconsole_helper_mapper.py --config %h/.config/uconsole-helper-mapper/config.toml
Restart=always
RestartSec=2

[Install]
WantedBy=default.target
