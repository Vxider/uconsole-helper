[general]
rescan_seconds = 3.0

[gamepad]
device_name_patterns = ["ClockworkPI uConsole"]
debounce_ms = 250

[[gamepad.bindings]]
buttons = ["BTN_TRIGGER"]
command = "~/.local/bin/toggle-uconsole-helper"

[[gamepad.bindings]]
buttons = ["BTN_TOP"]
command = "~/.local/bin/toggle-lxterminal"

[[gamepad.bindings]]
buttons = ["BTN_THUMB"]
command = "printf '%s' '提交git' | wl-copy && wtype -M ctrl -k v -m ctrl"

[[gamepad.bindings]]
buttons = ["BTN_THUMB"]
hold_ms = 700
text = "继续"
press_enter = true

# Push-to-talk voice input.
# Replace BTN_THUMB2 with the actual B key code on your device if needed.
# [[gamepad.bindings]]
# buttons = ["BTN_THUMB2"]
# press_command = "~/.local/bin/uconsole-voice-ptt start"
# release_command = "~/.local/bin/uconsole-voice-ptt stop"

[keyboard]
enabled = true
grab = false
device_name_patterns = ["ClockworkPI uConsole Keyboard", "keyd virtual keyboard"]
debounce_ms = 50
repeat_rate = 20
repeat_delay_ms = 600

# With grab disabled, bindings run side effects without intercepting the
# original key press. Esc still reaches the focused application.
[[keyboard.bindings]]
buttons = ["KEY_ESC"]
command = "~/.local/bin/esc-switch-ime-english"

# Desktop launcher bindings now live in:
#   ~/.config/uconsole-helper-mapper/desktop-keybinds.toml
# [[keyboard.bindings]]
# buttons = ["KEY_RIGHTSHIFT", "KEY_C"]
# command = "~/.local/bin/run-or-raise-chromium"
# [[keyboard.bindings]]
# buttons = ["KEY_LEFTSHIFT", "KEY_ENTER"]
# command = "~/.local/bin/shift-enter-newline"
# [[keyboard.bindings]]
# buttons = ["KEY_RIGHTSHIFT", "KEY_ENTER"]
# command = "~/.local/bin/shift-enter-newline"

[lock]
enabled = false
key = "KEY_COFFEE"
lock_command = "sudo -n /usr/local/bin/uconsole-helper-mapper-display-control off"
unlock_command = "sudo -n /usr/local/bin/uconsole-helper-mapper-display-control on"
keyboard_backlight_script = "~/WorkSpace/uconsole-keyboard/tools/keyboard_state.sh"

[power_button]
enabled = false
device_name_patterns = ["axp20x-pek"]
hold_ms = 700

[mouse]
enabled = true
grab = true
device_name_patterns = []

[[mouse.remaps]]
from = "BTN_MIDDLE"
to = "BTN_LEFT"
