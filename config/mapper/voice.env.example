ASR_URL=http://127.0.0.1:3300/api/asr/transcriptions

ASR_LANGUAGE=zh
# FlashAI personal ASR Token. Required; include asr:transcribe and asr:learn scopes.
ASR_AUTH_TOKEN=fa_asr_replace_me
# ASR_FINALIZE_URL=http://127.0.0.1:3300/api/asr/transcription-events/{requestId}/finalize
# Optional short ASR hint sent to the upstream transcription model.
# ASR_PROMPT=
# Multipart field name used for the ASR prompt.
# ASR_PROMPT_FIELD=prompt
# Multipart field name used for request-level glossary JSON.
# ASR_PROMPT_GLOSSARY_FIELD=promptGlossary
# User glossary file, one term per line.
# VOICE_GLOSSARY_FILE=~/.config/uconsole-helper-mapper/voice-glossary.txt
# Multipart field name used for tmux context sent to correction.
# ASR_CONTEXT_FIELD=contextText
# ASR correction mode: off | on | auto. Auto keeps normal text fast and corrects code/command mixed input.
ASR_CORRECTION_MODE=auto
ASR_NO_PROXY=1
# ASR request timeout in seconds. Use 0 to disable.
ASR_TIMEOUT=60

# Recorder selection: auto | pw-record | ffmpeg | arecord
VOICE_RECORDER=auto
VOICE_INPUT=default
VOICE_MIN_RECORD_MS=350
# Maximum recording duration before silently starting a new recording segment.
# Use 0 to disable.
VOICE_MAX_RECORD_MS=60000
VOICE_SAMPLE_RATE=16000
VOICE_CHANNELS=1

# Text injection mode: type | type_enter | clipboard | paste | fcitx_commit
# Non-tmux windows automatically fall back from type to fcitx_commit to avoid
# Wayland virtual-keyboard key-position output such as 1234567890.
VOICE_OUTPUT_MODE=paste
# Terminal windows keep direct typing even when normal windows use paste.
VOICE_TMUX_OUTPUT_MODE=type
# WeChat may not accept fcitx quick-phrase commits reliably; paste is safer.
VOICE_WECHAT_OUTPUT_MODE=paste
VOICE_PASTE_BACKEND=uinput
VOICE_PASTE_SHORTCUT=ctrl_v
VOICE_WECHAT_PASTE_SHORTCUT=ctrl_v
# VOICE_FCITX_COMMIT_FILE=~/.local/state/uconsole-helper-mapper/fcitx-voice-commit.txt
# VOICE_FCITX_COMMIT_TRIGGER=';uv'

# Keep recorded wav files for debugging: 0 | 1
VOICE_KEEP_AUDIO=0

# Show a WeChat-style floating preview while local pause detection uploads
# completed speech segments. Final text is injected once after the
# push-to-talk key is released.
VOICE_STREAM_PREVIEW=1
# Keep this off when the preview popup is enabled; error notifications still show.
VOICE_NOTIFY_WHILE_PREVIEW=0
VOICE_STREAM_PREVIEW_WIDTH=420
VOICE_STREAM_PREVIEW_HEIGHT=130
VOICE_STREAM_PREVIEW_OPACITY=1.0
VOICE_STREAM_PREVIEW_MAX_CHARS=36
VOICE_STREAM_SEND_INTERVAL_MS=200
# Silence duration before auto-uploading a speech segment.
# Smaller values make ASR split sooner on pauses.
VOICE_PAUSE_SEGMENT_MS=1600
VOICE_MIN_SEGMENT_MS=1000
VOICE_AUTO_SEGMENT_RMS_THRESHOLD=0.006
VOICE_AUTO_SEGMENT_NOISE_MARGIN=0.004

# Notification appearance.
VOICE_NOTIFY_USE_MARKUP=0
VOICE_NOTIFY_FONT_SIZE=22
VOICE_NOTIFY_PADDING_LINES=1

# When the active input is a tmux terminal window, include the current tmux
# active pane visible text as ASR context.
VOICE_TMUX_CONTEXT=1
# If the visible area is too short, fall back to at least this many recent lines.
# VOICE_TMUX_CONTEXT_LINES=30
# VOICE_TMUX_CONTEXT_MAX_CHARS=1200
# Short-press B correction dialog guardrails. Corrections too different from the last ASR text are rejected.
# VOICE_LEARN_MAX_AGE_SECONDS=600
# VOICE_LEARN_MAX_EDIT_RATIO=0.38
# VOICE_LEARN_REPLACE_INPUT=1
# VOICE_LEARN_REPLACE_MAX_CHARS=300
# VOICE_LEARN_DIALOG_FONT_SIZE=22
# VOICE_LEARN_DIALOG_WIDTH=820
# VOICE_LEARN_DIALOG_HEIGHT=220
